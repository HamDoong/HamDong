# Use the Vite same-origin proxy in development. This avoids CORS/preflight
# issues and preserves the backend's required /api/v1 prefix.
VITE_API_BASE_URL=/api/v1
VITE_API_PROXY_TARGET=http://localhost:8080

# Local-only fallback for identity routes if the API gateway returns 404/502.
VITE_IDENTITY_API_BASE_URL=http://localhost:8001/api/v1
