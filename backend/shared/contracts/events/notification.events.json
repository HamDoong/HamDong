{
  "$schema": "../schemas/event_envelope.schema.json",
  "service": "notification-service",
  "events": [
    {
      "event_type": "NotificationSent",
      "routing_key": "notification.sent",
      "payload_keys": [
        "notification_job_id",
        "channel",
        "notification_type",
        "recipient_email"
      ]
    },
    {
      "event_type": "NotificationFailed",
      "routing_key": "notification.failed",
      "payload_keys": [
        "notification_job_id",
        "channel",
        "notification_type",
        "recipient_email",
        "error"
      ]
    },
    {
      "event_type": "SmsSent",
      "routing_key": "notification.sms.sent",
      "payload_keys": [
        "notification_job_id",
        "recipient_email"
      ]
    },
    {
      "event_type": "SmsFailed",
      "routing_key": "notification.sms.failed",
      "payload_keys": [
        "notification_job_id",
        "recipient_email",
        "error"
      ]
    }
  ]
}