# HamDong IAM Service Environment Configuration

# Application
APP_NAME=HamDong IAM Service
APP_VERSION=1.0.0
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://hamdong_user:hamdong_pass@localhost:5432/hamdong_iam

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
JWT_SECRET_KEY=change-this-secret-key-in-production-12345678
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
OTP_SECRET_KEY=change-this-otp-secret-key-in-production

# OTP Configuration
OTP_TTL_SECONDS=120
OTP_LENGTH=6

# Rate Limiting
OTP_REQUESTS_PER_PHONE=3
OTP_REQUESTS_WINDOW_MINUTES=5
OTP_REQUESTS_PER_IP=10
OTP_REQUESTS_WINDOW_SECONDS=60

# SMS Service
SMS_PROVIDER=mock

# Logging
LOG_LEVEL=INFO
