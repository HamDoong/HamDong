@baseUrl = http://localhost:8080

@accessToken =
@groupId =
@payerUserId =
@participantUserId1 =
@participantUserId2 =
@participantUserId3 =
@expenseId =

### Health endpoint
GET {{baseUrl}}/api/v1/expenses/health/

### Create equal split expense
POST {{baseUrl}}/api/v1/groups/{{groupId}}/expenses/
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "شام رستوران",
  "description": "شام جمعه",
  "payer_user_id": "{{payerUserId}}",
  "base_amount_minor": 900000,
  "currency": "IRR",
  "split_method": "EQUAL",
  "participant_user_ids": [
    "{{participantUserId1}}",
    "{{participantUserId2}}",
    "{{participantUserId3}}"
  ],
  "tax_type": "NONE",
  "service_fee_type": "NONE"
}

### Create custom amount expense
POST {{baseUrl}}/api/v1/groups/{{groupId}}/expenses/
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "خرید مشترک",
  "description": "تقسیم سفارشی",
  "payer_user_id": "{{payerUserId}}",
  "base_amount_minor": 1000000,
  "currency": "IRR",
  "split_method": "CUSTOM_AMOUNT",
  "participants": [
    {
      "user_id": "{{participantUserId1}}",
      "base_share_minor": 400000
    },
    {
      "user_id": "{{participantUserId2}}",
      "base_share_minor": 300000
    },
    {
      "user_id": "{{participantUserId3}}",
      "base_share_minor": 300000
    }
  ],
  "tax_type": "FIXED",
  "tax_amount_minor": 100000,
  "service_fee_type": "NONE"
}

### List group expenses
GET {{baseUrl}}/api/v1/groups/{{groupId}}/expenses/
Authorization: Bearer {{accessToken}}

### Expense detail
GET {{baseUrl}}/api/v1/expenses/{{expenseId}}/
Authorization: Bearer {{accessToken}}

### Update expense
PATCH {{baseUrl}}/api/v1/expenses/{{expenseId}}/
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "شام رستوران - ویرایش شده",
  "tax_type": "PERCENTAGE",
  "tax_percentage": 10,
  "service_fee_type": "FIXED",
  "service_fee_amount_minor": 50000
}

### Delete expense
DELETE {{baseUrl}}/api/v1/expenses/{{expenseId}}/
Authorization: Bearer {{accessToken}}
