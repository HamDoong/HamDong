@baseUrl = http://localhost:8080

@aliEmail = ali@example.com
@saraEmail = sara@example.com
@aliOtp =
@saraOtp =
@aliAccessToken =
@saraAccessToken =
@aliArtName = ali_artist
@aliPassword = StrongPass123!
@aliNewPassword = NewStrongPass123!
@groupId =
@inviteToken =
@removedMemberId =
@notificationId =

### Identity health
GET {{baseUrl}}/api/v1/auth/health/

### Group health
GET {{baseUrl}}/api/v1/groups/health/

### Notification health
GET {{baseUrl}}/api/v1/notifications/health/

### 1. Request OTP for Ali
POST {{baseUrl}}/api/v1/auth/otp/request/
Content-Type: application/json

{
  "email": "{{aliEmail}}"
}

### 2. Verify OTP for Ali
POST {{baseUrl}}/api/v1/auth/otp/verify/
Content-Type: application/json

{
  "email": "{{aliEmail}}",
  "code": "{{aliOtp}}"
}

> {%
client.global.set("aliAccessToken", response.body.access_token);
%}

### 3. Set Ali art_name
PATCH {{baseUrl}}/api/v1/users/me/
Authorization: Bearer {{aliAccessToken}}
Content-Type: application/json

{
  "art_name": "{{aliArtName}}"
}

### 4. Set Ali password
POST {{baseUrl}}/api/v1/auth/password/set/
Authorization: Bearer {{aliAccessToken}}
Content-Type: application/json

{
  "new_password": "{{aliPassword}}",
  "new_password_confirm": "{{aliPassword}}"
}

### 5. Password login for Ali
POST {{baseUrl}}/api/v1/auth/password/login/
Content-Type: application/json

{
  "art_name": "{{aliArtName}}",
  "password": "{{aliPassword}}"
}

### 6. Change Ali password
POST {{baseUrl}}/api/v1/auth/password/change/
Authorization: Bearer {{aliAccessToken}}
Content-Type: application/json

{
  "current_password": "{{aliPassword}}",
  "new_password": "{{aliNewPassword}}",
  "new_password_confirm": "{{aliNewPassword}}"
}

### 7. Old password should fail
POST {{baseUrl}}/api/v1/auth/password/login/
Content-Type: application/json

{
  "art_name": "{{aliArtName}}",
  "password": "{{aliPassword}}"
}

### 8. New password should work
POST {{baseUrl}}/api/v1/auth/password/login/
Content-Type: application/json

{
  "art_name": "{{aliArtName}}",
  "password": "{{aliNewPassword}}"
}

### 9. Create group with title
POST {{baseUrl}}/api/v1/groups/
Authorization: Bearer {{aliAccessToken}}
Content-Type: application/json

{
  "title": "شام جمعه",
  "description": "دورهمی دوستانه",
  "group_type": "EVENT"
}

> {%
client.global.set("groupId", response.body.id);
%}

### 10. Archive group
POST {{baseUrl}}/api/v1/groups/{{groupId}}/archive/
Authorization: Bearer {{aliAccessToken}}

### 11. Restore group
POST {{baseUrl}}/api/v1/groups/{{groupId}}/restore/
Authorization: Bearer {{aliAccessToken}}

### 12. Create group with title_parts
POST {{baseUrl}}/api/v1/groups/
Authorization: Bearer {{aliAccessToken}}
Content-Type: application/json

{
  "title_parts": ["سفر", "شمال", "تابستان"],
  "description": "سفر چندروزه",
  "group_type": "TRIP"
}

### 13. Patch title_parts
PATCH {{baseUrl}}/api/v1/groups/{{groupId}}/
Authorization: Bearer {{aliAccessToken}}
Content-Type: application/json

{
  "title_parts": ["شام", "جمعه", "دوستان"]
}

### 14. Create invite
POST {{baseUrl}}/api/v1/groups/{{groupId}}/invites/
Authorization: Bearer {{aliAccessToken}}
Content-Type: application/json

{
  "max_uses": 3
}

> {%
const inviteUrl = response.body.invite_url || "";
if (inviteUrl) {
  client.global.set("inviteToken", inviteUrl.split("/").pop());
}
%}

### 15. Sara joins
POST {{baseUrl}}/api/v1/groups/invites/{{inviteToken}}/accept/
Authorization: Bearer {{saraAccessToken}}

> {%
client.global.set("removedMemberId", response.body.member_id);
%}

### 16. Remove Sara
POST {{baseUrl}}/api/v1/groups/{{groupId}}/members/{{removedMemberId}}/remove/
Authorization: Bearer {{aliAccessToken}}

### 17. Old invite should fail for removed member
POST {{baseUrl}}/api/v1/groups/invites/{{inviteToken}}/accept/
Authorization: Bearer {{saraAccessToken}}

### 18. Create new invite
POST {{baseUrl}}/api/v1/groups/{{groupId}}/invites/
Authorization: Bearer {{aliAccessToken}}
Content-Type: application/json

{
  "max_uses": 3
}

> {%
const inviteUrl2 = response.body.invite_url || "";
if (inviteUrl2) {
  client.global.set("inviteToken", inviteUrl2.split("/").pop());
}
%}

### 19. Sara rejoins with new invite
POST {{baseUrl}}/api/v1/groups/invites/{{inviteToken}}/accept/
Authorization: Bearer {{saraAccessToken}}

### 20. Delete group
DELETE {{baseUrl}}/api/v1/groups/{{groupId}}/
Authorization: Bearer {{aliAccessToken}}

### 21. Create notification
POST {{baseUrl}}/api/v1/notifications/
Authorization: Bearer {{aliAccessToken}}
Content-Type: application/json

{
  "channel": "IN_APP",
  "notification_type": "CUSTOM",
  "title": "یادآوری پرداخت",
  "body": "لطفاً سهم شام جمعه را تسویه کن.",
  "metadata": {}
}

> {%
client.global.set("notificationId", response.body.id);
%}

### 22. List notifications
GET {{baseUrl}}/api/v1/notifications/
Authorization: Bearer {{aliAccessToken}}

### 23. Notification detail
GET {{baseUrl}}/api/v1/notifications/{{notificationId}}/
Authorization: Bearer {{aliAccessToken}}

### 24. Edit notification
PATCH {{baseUrl}}/api/v1/notifications/{{notificationId}}/
Authorization: Bearer {{aliAccessToken}}
Content-Type: application/json

{
  "title": "یادآوری دوستانه",
  "body": "لطفاً هر وقت فرصت داشتی سهمت را پرداخت کن."
}

### 25. Delete notification
DELETE {{baseUrl}}/api/v1/notifications/{{notificationId}}/
Authorization: Bearer {{aliAccessToken}}
