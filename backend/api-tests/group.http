@baseUrl = http://localhost:8080

POST {{baseUrl}}/api/v1/groups/
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "title": "Demo Group",
  "group_type": "GENERAL"
}


POST {{baseUrl}}/api/v1/groups/{{groupId}}/invites/
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "expires_in_hours": 48,
  "max_uses": 5
}
