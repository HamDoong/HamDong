@baseUrl = http://localhost:8080

@aliPhone = 09120000001
@saraPhone = 09120000002
@rezaPhone = 09120000003

@aliOtp =
@saraOtp =
@rezaOtp =

@aliAccessToken =
@saraAccessToken =
@rezaAccessToken =

@aliRefreshToken =
@saraRefreshToken =
@rezaRefreshToken =

@aliUserId =
@saraUserId =
@rezaUserId =

@groupId =
@inviteToken =
@inviteId =

@mediaFileId =
@expenseId =

@settlementPlanId =
@settlementPlanItemId =
@manualSettlementId =

### 0) Health checks through the gateway
GET {{baseUrl}}/api/v1/auth/health/

###
GET {{baseUrl}}/api/v1/groups/health/

###
GET {{baseUrl}}/api/v1/expenses/health/

###
GET {{baseUrl}}/api/v1/media/health/

###
GET {{baseUrl}}/api/v1/settlements/health/

###
GET {{baseUrl}}/api/v1/notifications/health/

### 1) Request OTP for Ali
# If DEBUG=true returns debug_otp, copy it into @aliOtp manually.
POST {{baseUrl}}/api/v1/auth/otp/request/
Content-Type: application/json

{
  "phone_number": "{{aliPhone}}"
}

### 2) Verify OTP for Ali
# Copy access_token, refresh_token, and user.id from the response into @aliAccessToken, @aliRefreshToken, and @aliUserId.
POST {{baseUrl}}/api/v1/auth/otp/verify/
Content-Type: application/json

{
  "phone_number": "{{aliPhone}}",
  "code": "{{aliOtp}}"
}

### 3) Request OTP for Sara
# If DEBUG=true returns debug_otp, copy it into @saraOtp manually.
POST {{baseUrl}}/api/v1/auth/otp/request/
Content-Type: application/json

{
  "phone_number": "{{saraPhone}}"
}

### 4) Verify OTP for Sara
# Copy access_token, refresh_token, and user.id from the response into @saraAccessToken, @saraRefreshToken, and @saraUserId.
POST {{baseUrl}}/api/v1/auth/otp/verify/
Content-Type: application/json

{
  "phone_number": "{{saraPhone}}",
  "code": "{{saraOtp}}"
}

### 5) Request OTP for Reza
# If DEBUG=true returns debug_otp, copy it into @rezaOtp manually.
POST {{baseUrl}}/api/v1/auth/otp/request/
Content-Type: application/json

{
  "phone_number": "{{rezaPhone}}"
}

### 6) Verify OTP for Reza
# Copy access_token, refresh_token, and user.id from the response into @rezaAccessToken, @rezaRefreshToken, and @rezaUserId.
POST {{baseUrl}}/api/v1/auth/otp/verify/
Content-Type: application/json

{
  "phone_number": "{{rezaPhone}}",
  "code": "{{rezaOtp}}"
}

### 7) Ali creates a group
# Copy the created group id into @groupId.
POST {{baseUrl}}/api/v1/groups/
Authorization: Bearer {{aliAccessToken}}
Content-Type: application/json

{
  "title": "شام جمعه",
  "description": "دورهمی دوستانه",
  "group_type": "EVENT"
}

### 8) Ali creates an invite
# Copy invite_id into @inviteId.
# If the response only includes invite_url, copy the token from the end of invite_url into @inviteToken.
POST {{baseUrl}}/api/v1/groups/{{groupId}}/invites/
Authorization: Bearer {{aliAccessToken}}
Content-Type: application/json

{
  "expires_in_hours": 48,
  "max_uses": 5
}

### 9) Sara accepts the invite
POST {{baseUrl}}/api/v1/groups/invites/{{inviteToken}}/accept/
Authorization: Bearer {{saraAccessToken}}

### 10) Reza accepts the invite
POST {{baseUrl}}/api/v1/groups/invites/{{inviteToken}}/accept/
Authorization: Bearer {{rezaAccessToken}}

### 11) Ali lists group members
GET {{baseUrl}}/api/v1/groups/{{groupId}}/members/
Authorization: Bearer {{aliAccessToken}}

### 12) Sara uploads a receipt (optional)
# Optional step: requires api-tests/fixtures/receipt.jpg.
# If the fixture does not exist, skip this request and continue.
# Copy the uploaded file id into @mediaFileId if you use it.
POST {{baseUrl}}/api/v1/media/receipts/
Authorization: Bearer {{saraAccessToken}}
Content-Type: multipart/form-data; boundary=HamDongMediaBoundary

--HamDongMediaBoundary
Content-Disposition: form-data; name="group_id"

{{groupId}}
--HamDongMediaBoundary
Content-Disposition: form-data; name="file"; filename="receipt.jpg"
Content-Type: image/jpeg

< ./fixtures/receipt.jpg
--HamDongMediaBoundary--

### 13) Sara creates an equal split expense
# Expected shares:
# - Ali: 300000
# - Sara: 300000
# - Reza: 300000
# Copy the created expense id into @expenseId.
POST {{baseUrl}}/api/v1/groups/{{groupId}}/expenses/
Authorization: Bearer {{saraAccessToken}}
Content-Type: application/json

{
  "title": "شام رستوران",
  "description": "شام جمعه",
  "payer_user_id": "{{saraUserId}}",
  "base_amount_minor": 900000,
  "currency": "IRR",
  "split_method": "EQUAL",
  "participant_user_ids": [
    "{{aliUserId}}",
    "{{saraUserId}}",
    "{{rezaUserId}}"
  ],
  "tax_type": "NONE",
  "service_fee_type": "NONE"
}

### 14) Ali lists group expenses
GET {{baseUrl}}/api/v1/groups/{{groupId}}/expenses/
Authorization: Bearer {{aliAccessToken}}

### 15) Ali gets expense detail
GET {{baseUrl}}/api/v1/expenses/{{expenseId}}/
Authorization: Bearer {{aliAccessToken}}

### 16) Wait for async event consumers before checking balances
# Wait a few seconds for RabbitMQ consumers to process events before running the next request.

### 17) Ali gets group balances
# Expected balances after the expense:
# - Ali: -300000
# - Sara: +600000
# - Reza: -300000
GET {{baseUrl}}/api/v1/groups/{{groupId}}/balances/
Authorization: Bearer {{aliAccessToken}}

### 18) Ali gets group debts
# Expected debts after the expense:
# - Ali -> Sara: 300000
# - Reza -> Sara: 300000
GET {{baseUrl}}/api/v1/groups/{{groupId}}/debts/
Authorization: Bearer {{aliAccessToken}}

### 19) Ali generates the smart settlement plan
# Copy the settlement plan id into @settlementPlanId.
# Copy one Ali->Sara plan item id into @settlementPlanItemId.
POST {{baseUrl}}/api/v1/groups/{{groupId}}/settlement-plan/generate/
Authorization: Bearer {{aliAccessToken}}
Content-Type: application/json

{}

### 20) Wait for async event consumers if needed
# Wait a few seconds before reading or activating the plan when running the full demo.

### 21) Ali gets the latest settlement plan
# Expected settlement plan:
# - Ali -> Sara: 300000
# - Reza -> Sara: 300000
GET {{baseUrl}}/api/v1/groups/{{groupId}}/settlement-plan/
Authorization: Bearer {{aliAccessToken}}

### 22) Ali activates the settlement plan
POST {{baseUrl}}/api/v1/settlement-plans/{{settlementPlanId}}/activate/
Authorization: Bearer {{aliAccessToken}}

### 23) Ali reports his plan item as paid
# Copy manual_settlement_id into @manualSettlementId if you want to inspect the created manual settlement later.
POST {{baseUrl}}/api/v1/settlement-plan-items/{{settlementPlanItemId}}/report-paid/
Authorization: Bearer {{aliAccessToken}}
Content-Type: application/json

{
  "description": "پرداخت علی به سارا"
}

### 24) Sara confirms the plan item
POST {{baseUrl}}/api/v1/settlement-plan-items/{{settlementPlanItemId}}/confirm/
Authorization: Bearer {{saraAccessToken}}

### 25) Ali gets the final group balance
# Expected final balances after Ali pays and Sara confirms:
# - Ali: 0
# - Sara: +300000
# - Reza: -300000
GET {{baseUrl}}/api/v1/groups/{{groupId}}/balances/
Authorization: Bearer {{aliAccessToken}}
