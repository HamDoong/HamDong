### Expense-service health
GET http://localhost:8002/health/

### Create equal expense with integer minor units
POST http://localhost:8002/api/v1/groups/{{group_id}}/expenses/
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "title": "شام رستوران",
  "description": "شام جمعه",
  "payer_user_id": "{{payer_user_id}}",
  "base_amount_minor": 1200000,
  "currency": "IRR",
  "split_method": "EQUAL",
  "participant_user_ids": [
    "{{participant_user_id_1}}",
    "{{participant_user_id_2}}",
    "{{participant_user_id_3}}"
  ],
  "tax_type": "PERCENTAGE",
  "tax_percentage": "10.00",
  "service_fee_type": "FIXED",
  "service_fee_amount_minor": 50000,
  "expense_date": "2026-06-03T12:00:00Z"
}

### Create custom amount expense with integer minor units
POST http://localhost:8002/api/v1/groups/{{group_id}}/expenses/
Authorization: Bearer {{access_token}}
Content-Type: application/json

{
  "title": "خرید مشترک",
  "description": "خرید برای سفر",
  "payer_user_id": "{{payer_user_id}}",
  "base_amount_minor": 1000000,
  "currency": "IRR",
  "split_method": "CUSTOM_AMOUNT",
  "participants": [
    {
      "user_id": "{{participant_user_id_1}}",
      "base_share_minor": 400000
    },
    {
      "user_id": "{{participant_user_id_2}}",
      "base_share_minor": 300000
    },
    {
      "user_id": "{{participant_user_id_3}}",
      "base_share_minor": 300000
    }
  ],
  "tax_type": "FIXED",
  "tax_amount_minor": 100000,
  "service_fee_type": "NONE",
  "expense_date": "2026-06-03T12:00:00Z"
}
