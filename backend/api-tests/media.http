@baseUrl = http://localhost:8080

@accessToken =
@groupId =
@mediaFileId =

### Health endpoint
GET {{baseUrl}}/api/v1/media/health/

### Upload receipt
# Optional fixture path: api-tests/fixtures/receipt.jpg
# If the fixture does not exist yet, skip this request and continue the rest of the flow.
POST {{baseUrl}}/api/v1/media/receipts/
Authorization: Bearer {{accessToken}}
Content-Type: multipart/form-data; boundary=WebKitFormBoundary7MA4YWxkTrZu0gW

--WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="group_id"

{{groupId}}
--WebKitFormBoundary7MA4YWxkTrZu0gW
Content-Disposition: form-data; name="file"; filename="receipt.jpg"
Content-Type: image/jpeg

< ./fixtures/receipt.jpg
--WebKitFormBoundary7MA4YWxkTrZu0gW--

### Get media detail
GET {{baseUrl}}/api/v1/media/files/{{mediaFileId}}/
Authorization: Bearer {{accessToken}}

### Download media file
GET {{baseUrl}}/api/v1/media/files/{{mediaFileId}}/download/
Authorization: Bearer {{accessToken}}

### List group media
GET {{baseUrl}}/api/v1/groups/{{groupId}}/media/
Authorization: Bearer {{accessToken}}

### Delete media file
DELETE {{baseUrl}}/api/v1/media/files/{{mediaFileId}}/
Authorization: Bearer {{accessToken}}
