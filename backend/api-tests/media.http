@baseUrl = http://localhost:8080

@accessToken =
@groupId =
@mediaFileId =

### Media service health
GET {{baseUrl}}/api/v1/media/health/

### Upload receipt
# This repository snapshot does not include backend/api-tests/fixtures/receipt.jpg.
# Add that file first, then uncomment the request below to test upload.
#
# POST {{baseUrl}}/api/v1/media/receipts/
# Authorization: Bearer {{accessToken}}
# Content-Type: multipart/form-data; boundary=MediaBoundary
#
# --MediaBoundary
# Content-Disposition: form-data; name="group_id"
#
# {{groupId}}
# --MediaBoundary
# Content-Disposition: form-data; name="file"; filename="receipt.jpg"
# Content-Type: image/jpeg
#
# < ./fixtures/receipt.jpg
# --MediaBoundary--

### Media detail
GET {{baseUrl}}/api/v1/media/files/{{mediaFileId}}/
Authorization: Bearer {{accessToken}}

### Download media
GET {{baseUrl}}/api/v1/media/files/{{mediaFileId}}/download/
Authorization: Bearer {{accessToken}}

### List group media
GET {{baseUrl}}/api/v1/groups/{{groupId}}/media/
Authorization: Bearer {{accessToken}}

### Delete media
DELETE {{baseUrl}}/api/v1/media/files/{{mediaFileId}}/
Authorization: Bearer {{accessToken}}
