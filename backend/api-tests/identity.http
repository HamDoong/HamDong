@baseUrl = http://localhost:8080

@phone = 09120000001
@otp =
@accessToken =
@refreshToken =

### Identity health
GET {{baseUrl}}/api/v1/auth/health/

### Request OTP
# If DEBUG=true returns debug_otp, copy it manually into @otp before the verify request.
POST {{baseUrl}}/api/v1/auth/otp/request/
Content-Type: application/json

{
  "phone_number": "{{phone}}"
}

### Verify OTP
# Copy access_token and refresh_token from the response into @accessToken and @refreshToken.
POST {{baseUrl}}/api/v1/auth/otp/verify/
Content-Type: application/json

{
  "phone_number": "{{phone}}",
  "code": "{{otp}}"
}

### Get current user
GET {{baseUrl}}/api/v1/users/me/
Authorization: Bearer {{accessToken}}

### Update current user
PATCH {{baseUrl}}/api/v1/users/me/
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "display_name": "علی"
}

### Refresh token
POST {{baseUrl}}/api/v1/auth/token/refresh/
Content-Type: application/json

{
  "refresh_token": "{{refreshToken}}"
}

### Logout
POST {{baseUrl}}/api/v1/auth/logout/
Content-Type: application/json

{
  "refresh_token": "{{refreshToken}}"
}

### JWKS
# Preferred working route for this project.
GET {{baseUrl}}/api/v1/auth/jwks/
