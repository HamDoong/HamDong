@baseUrl = http://localhost:8080

@phoneNumber = 09120000001
@debugOtp =
@accessToken =
@refreshToken =

### Identity health
GET {{baseUrl}}/api/v1/auth/health/

### Request OTP
# When DEBUG=true, copy debug_otp from the response into @debugOtp manually.
POST {{baseUrl}}/api/v1/auth/otp/request/
Content-Type: application/json

{
  "phone_number": "{{phoneNumber}}"
}

### Verify OTP
POST {{baseUrl}}/api/v1/auth/otp/verify/
Content-Type: application/json

{
  "phone_number": "{{phoneNumber}}",
  "code": "{{debugOtp}}"
}

### Get current user
GET {{baseUrl}}/api/v1/users/me/
Authorization: Bearer {{accessToken}}

### Update current user
PATCH {{baseUrl}}/api/v1/users/me/
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "display_name": "علی"
}

### Refresh token
POST {{baseUrl}}/api/v1/auth/token/refresh/
Content-Type: application/json

{
  "refresh_token": "{{refreshToken}}"
}

### Logout
POST {{baseUrl}}/api/v1/auth/logout/
Content-Type: application/json

{
  "refresh_token": "{{refreshToken}}"
}

### JWKS
GET {{baseUrl}}/api/v1/auth/jwks/

### Well-known JWKS
# This project exposes the working route without a trailing slash.
GET {{baseUrl}}/api/v1/auth/.well-known/jwks.json
