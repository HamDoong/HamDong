@baseUrl = http://localhost:8080

@accessToken =
@phoneNumber = 09120000001

### Notification service health
GET {{baseUrl}}/api/v1/notifications/health/

### Send test SMS
# This endpoint is intended for local/debug environments only.
POST {{baseUrl}}/api/v1/notifications/sms/test/
Content-Type: application/json

{
  "phone_number": "{{phoneNumber}}",
  "message": "Test SMS"
}

### List messages
# This endpoint is intended for local/debug environments only.
GET {{baseUrl}}/api/v1/notifications/messages/
