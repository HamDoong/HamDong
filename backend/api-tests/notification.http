@baseUrl = http://localhost:8080

@accessToken =
@phoneNumber = 09120000001
@notificationId =

### Health endpoint
GET {{baseUrl}}/api/v1/notifications/health/

### Send test SMS
POST {{baseUrl}}/api/v1/notifications/sms/test/
Content-Type: application/json

{
  "phone_number": "{{phoneNumber}}",
  "message": "HamDong notification test"
}

### List notification messages
GET {{baseUrl}}/api/v1/notifications/messages/
Authorization: Bearer {{accessToken}}

### Create custom notification
POST {{baseUrl}}/api/v1/notifications/
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "channel": "IN_APP",
  "notification_type": "CUSTOM",
  "title": "یادآوری پرداخت",
  "body": "لطفاً سهم شام جمعه را تسویه کن.",
  "metadata": {
    "group_id": "11111111-1111-1111-1111-111111111111",
    "amount_minor": 300000
  }
}

### List inbox notifications
GET {{baseUrl}}/api/v1/notifications/
Authorization: Bearer {{accessToken}}

### Get notification detail
GET {{baseUrl}}/api/v1/notifications/{{notificationId}}/
Authorization: Bearer {{accessToken}}

### Edit notification
PATCH {{baseUrl}}/api/v1/notifications/{{notificationId}}/
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "title": "یادآوری دوستانه",
  "body": "لطفاً هر وقت فرصت داشتی سهمت را پرداخت کن."
}

### Delete notification
DELETE {{baseUrl}}/api/v1/notifications/{{notificationId}}/
Authorization: Bearer {{accessToken}}
