APP_ENV=local
DEBUG=true
SECRET_KEY=change-me

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=hamdong
POSTGRES_PASSWORD=hamdong_password

IDENTITY_DB_NAME=identity_db
GROUP_DB_NAME=group_db
EXPENSE_DB_NAME=expense_db
SETTLEMENT_DB_NAME=settlement_db
MEDIA_DB_NAME=media_db
NOTIFICATION_DB_NAME=notification_db

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_DEFAULT_USER=hamdong
RABBITMQ_DEFAULT_PASS=hamdong_password
RABBITMQ_MANAGEMENT_PORT=15672

JWT_ALGORITHM=RS256
JWT_ISSUER=hamdong.identity-service
JWT_AUDIENCE=hamdong.services
JWT_ACCESS_TOKEN_LIFETIME_SECONDS=900
JWT_REFRESH_TOKEN_LIFETIME_SECONDS=604800
JWT_PRIVATE_KEY_PATH=/app/keys/private.pem
JWT_PUBLIC_KEY_PATH=/app/keys/public.pem

OTP_LENGTH=6
OTP_TTL_SECONDS=120
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_VERIFY_ATTEMPTS=5
OTP_MAX_REQUESTS_PER_WINDOW=3
OTP_RATE_LIMIT_WINDOW_SECONDS=600
OTP_DEBUG_RETURN_CODE=true

IDENTITY_RABBITMQ_EXCHANGE=hamdong.identity
NOTIFICATION_RABBITMQ_EXCHANGE=hamdong.notification
IDENTITY_OTP_QUEUE=notification.identity.otp.requested
IDENTITY_OTP_DLX=notification.identity.otp.requested.dlx
IDENTITY_OTP_DLQ=notification.identity.otp.requested.dlq

SMS_PROVIDER=fake
SMS_API_KEY=
SMS_SENDER=
SMS_TEMPLATE_OTP_LOGIN=OTP_LOGIN
SMS_TEMPLATE_SETTLEMENT_REMINDER=SETTLEMENT_REMINDER
SMS_TEMPLATE_PAYMENT_REMINDER=PAYMENT_REMINDER
SMS_TEMPLATE_SETTLEMENT_CONFIRMATION_REMINDER=SETTLEMENT_CONFIRMATION_REMINDER
SMS_TEMPLATE_PLAN_ITEM_REMINDER=PLAN_ITEM_REMINDER
SMS_CIRCUIT_FAIL_MAX=5
SMS_CIRCUIT_RESET_TIMEOUT_SECONDS=60
SMS_OTP_MAX_RETRIES=2
SMS_OTP_RETRY_DELAYS_SECONDS=10,30

# Phase 4 group-service / invite settings
GROUP_RABBITMQ_EXCHANGE=hamdong.group

IDENTITY_RABBITMQ_EXCHANGE=hamdong.identity
GROUP_IDENTITY_QUEUE=group.identity.user_events

IDENTITY_JWKS_URL=http://identity-service:8000/api/v1/auth/.well-known/jwks.json
IDENTITY_PUBLIC_KEY_PATH=/app/keys/public.pem

JWT_ISSUER=hamdong.identity-service
JWT_AUDIENCE=hamdong.services
JWT_ALGORITHM=RS256

INVITE_BASE_URL=http://localhost:3000/invites
INVITE_TOKEN_BYTES=32
INVITE_DEFAULT_EXPIRES_HOURS=72
INVITE_MAX_EXPIRES_HOURS=168
INVITE_DEFAULT_MAX_USES=10

# Expense service
EXPENSE_RABBITMQ_EXCHANGE=hamdong.expense
EXPENSE_IDENTITY_QUEUE=expense.identity.user_events
EXPENSE_GROUP_QUEUE=expense.group.events
EXPENSE_DB_NAME=expense_db
DEFAULT_CURRENCY=IRR
MAX_EXPENSE_AMOUNT_MINOR=100000000000

# Settlement service
SETTLEMENT_RABBITMQ_EXCHANGE=hamdong.settlement
SETTLEMENT_IDENTITY_QUEUE=settlement.identity.user_events
SETTLEMENT_GROUP_QUEUE=settlement.group.events
SETTLEMENT_EXPENSE_QUEUE=settlement.expense.events
SETTLEMENT_DB_NAME=settlement_db
MAX_SETTLEMENT_AMOUNT_MINOR=100000000000
EVENT_OUTBOX_BATCH_SIZE=50
EVENT_OUTBOX_POLL_INTERVAL_SECONDS=5
EVENT_MAX_RETRY_COUNT=5
EVENT_RETRY_DELAY_SECONDS=10,30,60
EVENT_DLQ_SUFFIX=.dlq
REMINDER_ENABLED=true
REMINDER_MIN_INTERVAL_HOURS=24
REMINDER_SCHEDULER_INTERVAL_SECONDS=3600
PENDING_SETTLEMENT_REMINDER_AFTER_HOURS=24
PLAN_ITEM_REMINDER_AFTER_HOURS=24
PAYMENT_REMINDER_MIN_AMOUNT_MINOR=1000
SETTLEMENT_REMINDER_EXCHANGE=hamdong.settlement
SETTLEMENT_REMINDER_QUEUE=notification.settlement.reminders
SETTLEMENT_REMINDER_DLX=notification.settlement.reminders.dlx
SETTLEMENT_REMINDER_DLQ=notification.settlement.reminders.dlq
NOTIFICATION_REMINDER_QUEUE=notification.reminders

IDENTITY_JWKS_URL=http://identity-service:8000/api/v1/auth/.well-known/jwks.json
IDENTITY_PUBLIC_KEY_PATH=/app/keys/public.pem

# Media service
MEDIA_RABBITMQ_EXCHANGE=hamdong.media
MEDIA_IDENTITY_QUEUE=media.identity.user_events
MEDIA_GROUP_QUEUE=media.group.events
MEDIA_STORAGE_PROVIDER=local
MEDIA_ROOT=/media/uploads
MEDIA_MAX_FILE_SIZE_BYTES=5242880
MEDIA_ALLOWED_EXTENSIONS=jpg,jpeg,png,webp,pdf
MEDIA_ALLOWED_CONTENT_TYPES=image/jpeg,image/png,image/webp,application/pdf
MEDIA_SIGNED_URL_EXPIRES_SECONDS=300
