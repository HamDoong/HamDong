{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Standard Event Envelope",
  "type": "object",
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "event_type": {
      "type": "string"
    },
    "event_version": {
      "type": "integer",
      "minimum": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "source_service": {
      "type": "string"
    },
    "correlation_id": {
      "type": "string",
      "format": "uuid"
    },
    "causation_id": {
      "type": "string",
      "format": "uuid"
    },
    "routing_key": {
      "type": "string"
    },
    "data": {
      "type": "object"
    }
  },
  "required": [
    "event_id",
    "event_type",
    "event_version",
    "occurred_at",
    "source_service",
    "correlation_id",
    "causation_id",
    "routing_key",
    "data"
  ]
}
