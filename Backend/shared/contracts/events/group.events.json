{
  "$schema": "../schemas/event_envelope.schema.json",
  "service": "group-service",
  "events": [
    {
      "event_type": "GroupCreated",
      "routing_key": "group.created",
      "payload_keys": [
        "group_id",
        "title",
        "description",
        "group_type",
        "status",
        "created_by_user_id",
        "created_by_email",
        "member_count"
      ]
    },
    {
      "event_type": "GroupUpdated",
      "routing_key": "group.updated",
      "payload_keys": [
        "group_id",
        "title",
        "description",
        "group_type",
        "status",
        "updated_by_user_id",
        "member_count"
      ]
    },
    {
      "event_type": "GroupArchived",
      "routing_key": "group.archived",
      "payload_keys": [
        "group_id",
        "archived_by_user_id",
        "status"
      ]
    },
    {
      "event_type": "GroupInviteCreated",
      "routing_key": "group.invite.created",
      "payload_keys": [
        "group_id",
        "invite_id",
        "created_by_user_id"
      ]
    },
    {
      "event_type": "GroupInviteAccepted",
      "routing_key": "group.invite.accepted",
      "payload_keys": [
        "group_id",
        "invite_id",
        "user_id"
      ]
    },
    {
      "event_type": "GroupMemberJoined",
      "routing_key": "group.member.joined",
      "payload_keys": [
        "group_id",
        "user_id",
        "email",
        "art_name",
        "role",
        "status"
      ]
    },
    {
      "event_type": "GroupMemberRemoved",
      "routing_key": "group.member.removed",
      "payload_keys": [
        "group_id",
        "user_id",
        "member_id",
        "removed_by_user_id",
        "status"
      ]
    },
    {
      "event_type": "GroupMemberLeft",
      "routing_key": "group.member.left",
      "payload_keys": [
        "group_id",
        "user_id",
        "left_by_user_id",
        "status"
      ]
    },
    {
      "event_type": "GroupInviteRevoked",
      "routing_key": "group.invite.revoked",
      "payload_keys": [
        "group_id",
        "invite_id",
        "revoked_by_user_id"
      ]
    }
  ]
}