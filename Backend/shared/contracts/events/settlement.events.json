{
  "$schema": "../schemas/event_envelope.schema.json",
  "service": "settlement-service",
  "events": [
    {
      "event_type": "SettlementCreated",
      "routing_key": "settlement.created",
      "payload_keys": [
        "settlement_id",
        "group_id",
        "payer_user_id",
        "receiver_user_id",
        "amount_minor",
        "currency",
        "status"
      ]
    },
    {
      "event_type": "SettlementConfirmed",
      "routing_key": "settlement.confirmed",
      "payload_keys": [
        "settlement_id",
        "group_id",
        "payer_user_id",
        "receiver_user_id",
        "amount_minor",
        "currency",
        "confirmed_by_user_id"
      ]
    },
    {
      "event_type": "SettlementRejected",
      "routing_key": "settlement.rejected",
      "payload_keys": [
        "settlement_id",
        "group_id",
        "payer_user_id",
        "receiver_user_id",
        "amount_minor",
        "currency",
        "rejected_by_user_id",
        "reason"
      ]
    },
    {
      "event_type": "SettlementCancelled",
      "routing_key": "settlement.cancelled",
      "payload_keys": [
        "settlement_id",
        "group_id",
        "payer_user_id",
        "receiver_user_id",
        "amount_minor",
        "currency",
        "cancelled_by_user_id"
      ]
    },
    {
      "event_type": "BalanceRecalculated",
      "routing_key": "settlement.balance_recalculated",
      "payload_keys": [
        "group_id",
        "currency",
        "balances"
      ]
    },
    {
      "event_type": "DebtLedgerUpdated",
      "routing_key": "settlement.debt_ledger_updated",
      "payload_keys": [
        "group_id",
        "currency",
        "source_expense_id",
        "source_settlement_id",
        "entry_ids",
        "status"
      ]
    },
    {
      "event_type": "SettlementPlanGenerated",
      "routing_key": "settlement.plan.generated",
      "payload_keys": [
        "plan_id",
        "group_id",
        "currency",
        "transaction_count",
        "total_debt_minor",
        "status",
        "items"
      ]
    },
    {
      "event_type": "SettlementPlanActivated",
      "routing_key": "settlement.plan.activated",
      "payload_keys": [
        "plan_id",
        "group_id",
        "activated_by_user_id",
        "status"
      ]
    },
    {
      "event_type": "SettlementPlanCancelled",
      "routing_key": "settlement.plan.cancelled",
      "payload_keys": [
        "plan_id",
        "group_id",
        "cancelled_by_user_id",
        "status"
      ]
    },
    {
      "event_type": "SettlementPlanExpired",
      "routing_key": "settlement.plan.expired",
      "payload_keys": [
        "plan_id",
        "group_id",
        "status"
      ]
    },
    {
      "event_type": "SettlementPlanCompleted",
      "routing_key": "settlement.plan.completed",
      "payload_keys": [
        "plan_id",
        "group_id",
        "completed_at",
        "status"
      ]
    },
    {
      "event_type": "SettlementPlanItemReported",
      "routing_key": "settlement.plan_item.reported",
      "payload_keys": [
        "plan_id",
        "item_id",
        "group_id",
        "payer_user_id",
        "receiver_user_id",
        "amount_minor",
        "manual_settlement_id",
        "currency",
        "status"
      ]
    },
    {
      "event_type": "SettlementPlanItemConfirmed",
      "routing_key": "settlement.plan_item.confirmed",
      "payload_keys": [
        "plan_id",
        "item_id",
        "group_id",
        "payer_user_id",
        "receiver_user_id",
        "amount_minor",
        "currency",
        "status",
        "wallet_transaction_id"
      ]
    },
    {
      "event_type": "SettlementPlanItemRejected",
      "routing_key": "settlement.plan_item.rejected",
      "payload_keys": [
        "plan_id",
        "item_id",
        "group_id",
        "payer_user_id",
        "receiver_user_id",
        "amount_minor",
        "currency",
        "status"
      ]
    },
    {
      "event_type": "PaymentReminderRequested",
      "routing_key": "settlement.payment_reminder.requested",
      "payload_keys": [
        "group_id",
        "target_user_id",
        "target_email",
        "target_art_name",
        "amount_minor",
        "currency",
        "reason",
        "message_context"
      ]
    },
    {
      "event_type": "SettlementConfirmationReminderRequested",
      "routing_key": "settlement.confirmation_reminder.requested",
      "payload_keys": [
        "settlement_id",
        "group_id",
        "receiver_user_id",
        "receiver_email",
        "payer_art_name",
        "amount_minor",
        "currency"
      ]
    },
    {
      "event_type": "SettlementPlanItemReminderRequested",
      "routing_key": "settlement.plan_item_reminder.requested",
      "payload_keys": [
        "plan_id",
        "item_id",
        "group_id",
        "payer_user_id",
        "payer_email",
        "receiver_art_name",
        "amount_minor",
        "currency",
        "message_context"
      ]
    },
    {
      "event_type": "DebtReminderRequested",
      "routing_key": "settlement.debt_reminder.requested",
      "payload_keys": [
        "reminder_id",
        "source",
        "sequence_number",
        "group_id",
        "group_title",
        "settlement_plan_id",
        "settlement_plan_item_id",
        "recipient_user_id",
        "recipient_email",
        "creditor_user_id",
        "creditor_name",
        "amount_minor",
        "currency",
        "send_in_app",
        "send_email",
        "requested_by_user_id"
      ]
    }
  ]
}
