@baseUrl = http://localhost:8080

@phone = 09120000001
@otp =
@accessToken =
@refreshToken =
@artName = ali_artist
@oldPassword = StrongPass123!
@newPassword = NewStrongPass123!

### Health endpoint
GET {{baseUrl}}/api/v1/auth/health/

### Request OTP
POST {{baseUrl}}/api/v1/auth/otp/request/
Content-Type: application/json

{
  "email": "{{phone}}"
}

### Verify OTP
POST {{baseUrl}}/api/v1/auth/otp/verify/
Content-Type: application/json

{
  "email": "{{phone}}",
  "code": "{{otp}}"
}

### Refresh access token
POST {{baseUrl}}/api/v1/auth/token/refresh/
Content-Type: application/json

{
  "refresh_token": "{{refreshToken}}"
}

### Logout
POST {{baseUrl}}/api/v1/auth/logout/
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "refresh_token": "{{refreshToken}}"
}

### Get current user
GET {{baseUrl}}/api/v1/users/me/
Authorization: Bearer {{accessToken}}

### Update current user with art_name
PATCH {{baseUrl}}/api/v1/users/me/
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "art_name": "Ali Demo",
  "art_name": "{{artName}}",
  "first_name": "Ali",
  "last_name": "Tester"
}

### Set password
POST {{baseUrl}}/api/v1/auth/password/set/
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "new_password": "{{oldPassword}}",
  "new_password_confirm": "{{oldPassword}}"
}

### Password login
POST {{baseUrl}}/api/v1/auth/password/login/
Content-Type: application/json

{
  "art_name": "{{artName}}",
  "password": "{{oldPassword}}"
}

### Change password
POST {{baseUrl}}/api/v1/auth/password/change/
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "current_password": "{{oldPassword}}",
  "new_password": "{{newPassword}}",
  "new_password_confirm": "{{newPassword}}"
}

### JWKS endpoint
GET {{baseUrl}}/api/v1/auth/.well-known/jwks.json
