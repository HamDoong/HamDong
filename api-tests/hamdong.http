### HamDong demo API tests
@baseUrl = http://localhost:8080

# 1) Request OTP
POST {{baseUrl}}/api/v1/auth/otp/request/
Content-Type: application/json

{
  "phone_number": "+15555550123"
}

# 2) Verify OTP (replace with code from logs)
POST {{baseUrl}}/api/v1/auth/otp/verify/
Content-Type: application/json

{
  "phone_number": "+15555550123",
  "code": "000000"
}

# 3) Create a group (requires Authorization: Bearer <token>)
POST {{baseUrl}}/api/v1/groups/
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "title": "Demo Group",
  "group_type": "GENERAL"
}

# 4) Create an expense in the group
POST {{baseUrl}}/api/v1/groups/{{groupId}}/expenses/
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
  "title": "Lunch",
  "amount": 45.50,
  "paid_by": "{{memberId}}",
  "participants": ["{{memberId}}"]
}

# 5) Generate settlement plan
POST {{baseUrl}}/api/v1/groups/{{groupId}}/settlement-plan/generate/
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{}

# 6) Trigger SMS test endpoint
POST {{baseUrl}}/api/v1/notifications/sms/test/
Content-Type: application/json

{
  "to": "+15555550123",
  "message": "Test SMS from HamDong"
}
